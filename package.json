{
  "name": "zhifa",
  "version": "1.0.0",
  "productName": "知发",
  "description": "知发 - 笔记多平台发布工具",
  "main": "src/electron-main.js",
  "scripts": {
    "start": "node src/server.js",
    "desktop": "electron .",
    "dist:win": "electron-builder --win portable --publish never",
    "dist:mac": "electron-builder --mac zip --publish never",
    "check:syntax": "node --check src/config-store.js && node --check src/server.js && node --check src/scheduler.js && node --check src/publisher.js && node --check src/check.js && node --check src/feishu.js && node --check src/electron-main.js",
    "check": "node src/check.js",
    "backup:tag": "sh scripts/tag-backup.sh",
    "git:sync": "sh scripts/git-sync.sh",
    "release:mac-local": "sh scripts/upload-local-mac-release.sh"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.xiwenran.zhifa",
    "productName": "知发",
    "asar": false,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json",
      "!config.example.json",
      "!config.json",
      "!publish-ledger.json",
      "!README.md",
      "!MEMORY.md",
      "!memory{,/**/*}",
      "!.claude{,/**/*}",
      "!.codepilot-uploads{,/**/*}",
      "!小雨老师{,/**/*}",
      "!scripts{,/**/*}",
      "!启动.command",
      "!dist{,/**/*}",
      "!.github{,/**/*}"
    ],
    "extraMetadata": {
      "main": "src/electron-main.js"
    },
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "zip"
      ],
      "artifactName": "${productName} macOS.${ext}",
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ],
      "artifactName": "${productName} Portable.${ext}",
      "executableName": "Zhifa"
    }
  },
  "keywords": [
    "yixiaoer",
    "publish",
    "feishu",
    "douyin",
    "xiaohongshu"
  ],
  "author": "",
  "license": "MIT"
}
