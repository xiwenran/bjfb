{
  "name": "yixiaoer-publisher",
  "version": "1.0.0",
  "productName": "NotePublisher",
  "description": "笔记发布工具 - 飞书驱动的多平台自动发布工具",
  "main": "src/electron-main.js",
  "scripts": {
    "start": "node src/server.js",
    "desktop": "electron .",
    "dist:win": "electron-builder --win portable --publish never",
    "dist:mac": "electron-builder --mac zip --publish never",
    "check:syntax": "node --check src/config-store.js && node --check src/server.js && node --check src/scheduler.js && node --check src/publisher.js && node --check src/check.js && node --check src/feishu.js && node --check src/electron-main.js",
    "check": "node src/check.js",
    "backup:tag": "sh scripts/tag-backup.sh",
    "git:sync": "sh scripts/git-sync.sh",
    "release:mac-local": "sh scripts/upload-local-mac-release.sh"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "playwright-core": "^1.58.2"
  },
  "devDependencies": {
    "electron": "^37.10.3",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.xiwenran.notepublisher",
    "productName": "NotePublisher",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "package.json",
      "!config.example.json",
      "!config.json",
      "!publish-ledger.json",
      "!README.md",
      "!MEMORY.md",
      "!memory{,/**/*}",
      "!.claude{,/**/*}",
      "!.codepilot-uploads{,/**/*}",
      "!小雨老师{,/**/*}",
      "!scripts{,/**/*}",
      "!启动.command",
      "!dist{,/**/*}",
      "!.github{,/**/*}"
    ],
    "extraMetadata": {
      "main": "src/electron-main.js"
    },
    "mac": {
      "target": [
        "zip"
      ],
      "artifactName": "${productName} macOS.${ext}",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "${productName} Portable.${ext}",
      "executableName": "NotePublisher"
    }
  },
  "keywords": [
    "yixiaoer",
    "publish",
    "feishu",
    "douyin",
    "xiaohongshu"
  ],
  "author": "",
  "license": "MIT"
}
